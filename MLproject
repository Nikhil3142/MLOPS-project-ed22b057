name: insurance-mlops

python_env: python_env.yaml

entry_points:
  preprocess:
    command: "MLFLOW_RUN_ID= python pipeline/preprocess.py"

  train:
    command: "MLFLOW_RUN_ID= PYTHONPATH=. python pipeline/train.py"

  evaluate:
    command: "MLFLOW_RUN_ID= PYTHONPATH=. python pipeline/evaluate.py"

  register:
    command: "MLFLOW_RUN_ID= PYTHONPATH=. python pipeline/register.py"

  main:
    command: "MLFLOW_RUN_ID= dvc repro"